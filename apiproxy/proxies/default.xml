<ProxyEndpoint name="default">
    <PreFlow name="PreFlow">
        <Request>
            <Step><Name>verify-apikey</Name></Step>
            <Step>
                <Name>response-cache</Name>
                <Condition>request.verb = "GET"</Condition>
            </Step>
            <Step><Name>quota</Name></Step>
        </Request>
        <Response/>
    </PreFlow>
    <PostFlow name="PostFlow">
        <Request/>
        <Response>
            <Step>
                <Name>response-cache</Name>
                <Condition>request.verb = "GET"</Condition>
            </Step>
        </Response>
    </PostFlow>
    <HTTPProxyConnection><BasePath>/v1/conditional-order</BasePath></HTTPProxyConnection>
    <RouteRule name="method-gate">
        <Condition>request.verb = "GET" or request.verb = "POST"</Condition>
        <TargetEndpoint>microservice-1</TargetEndpoint>
    </RouteRule>
    <RouteRule name="default">
        <TargetEndpoint>microservice-1</TargetEndpoint>
    </RouteRule>
</ProxyEndpoint>
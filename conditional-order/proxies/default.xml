<ProxyEndpoint name="default">
    <PreFlow name="PreFlow">
        <Request>
            <Step><Name>verify-apikey</Name></Step>
            <Step>
                <Name>response-cache</Name>
                <Condition>request.verb = "GET"</Condition>
            </Step>
            <Step><Name>spike-arrest</Name></Step>
        </Request>
        <Response/>
    </PreFlow>
    <PostFlow name="PostFlow">
        <Request/>
        <Response>
            <Step>
                <Name>response-cache</Name>
                <Condition>request.verb = "GET"</Condition>
            </Step>
        </Response>
    </PostFlow>
    <HTTPProxyConnection>
        <BasePath>/v1/customer-order</BasePath>
    </HTTPProxyConnection>
    <RouteRule name="get-microservice-1">
        <Condition>request.verb = "GET"</Condition>
        <TargetEndpoint>microservice-1</TargetEndpoint>
    </RouteRule>
    <RouteRule name="post-microservice-2">
        <Condition>request.verb = "POST"</Condition>
        <TargetEndpoint>microservice-2</TargetEndpoint>
    </RouteRule>
    <RouteRule name="default">
        <TargetEndpoint>microservice-1</TargetEndpoint>
    </RouteRule>
</ProxyEndpoint>